{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "install": {
      "inputs": [
        { "step": "packages" },
        { "local": true, "include": ["."] }
      ],
      "commands": ["pip install -r requirements_bot.txt"]
    }
  },
  "deploy": {
    "startCommand": "python discord_bot.py"
  }
}
